{
  "name": "drink3-solution",
  "private": true,
  "version": "1.0.0",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "scripts": {
    "prepare": "pnpm -C web install",
    "generate": "pnpm -C web --filter @app/api-types generate",
    "build:web": "pnpm -C web build",
    "build:admin": "pnpm -C web --filter @drink/admin build",
    "build:client": "pnpm -C web --filter @drink/client build",
    "dev:api": "dotnet watch --project api/yyy/yyy.csproj",
    "dev:web": "pnpm -C web dev",
    "dev": "concurrently -n \"API,WEB\" -c \"magenta,cyan\" \"npm run dev:api\" \"npm run dev:web\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1"
}